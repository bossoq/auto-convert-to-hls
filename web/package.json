    "eslint": "^8.0.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-svelte": "^2.0.0",
    "postcss": "^8.4.7",
    "prettier": "^2.5.1",
    "prettier-plugin-svelte": "^2.5.0",
    "svelte": "^4.0.0",
    "svelte-check": "^3.0.0",
    "svelte-eslint-parser": "^0.36.0",
